#ifndef NCONPP_GRAPH_H
#define NCONPP_GRAPH_H

#include <boost/graph/adjacency_list.hpp>

template <typename V = boost::property<boost::vertex_index_t, std::size_t>, typename E = boost::property<boost::edge_index_t, std::size_t>>
class Graph
{
public:
    typedef typename boost::adjacency_list<boost::multisetS, boost::vecS, boost::undirectedS, V, E> graph_t;

    typedef typename boost::graph_traits<graph_t>::vertex_descriptor vertex_descriptor;
    typedef typename boost::graph_traits<graph_t>::adjacency_iterator adjacency_iterator;
    typedef typename boost::graph_traits<graph_t>::vertex_iterator vertex_iterator;
    typedef typename boost::property_map<graph_t, boost::vertex_index_t>::type vertex_index_property_map_t;

    typedef typename boost::graph_traits<graph_t>::edge_descriptor edge_descriptor;
    typedef typename boost::graph_traits<graph_t>::edge_iterator edge_iterator;
    typedef typename boost::property_map<graph_t, boost::edge_index_t>::type edge_index_property_map_t;

    graph_t detail;

    Graph(std::size_t N) : detail(N){};

    ~Graph() = default;

    /**
     * @brief Add a new vertex to the graph and return its id.
     *
     * @return std::size_t
     */
    std::size_t addVertex()
    {
        auto v = boost::add_vertex(detail);
        return v;
    }

    /**
     * @brief Remove a vertex from the graph by id.
     * All edges corresponding to the vertex are removed beforehand.
     *
     * @param id
     */
    void removeVertex(std::size_t id)
    {
        boost::clear_vertex(id, detail); // ensure all edges to vertex are removed beforehand
        boost::remove_vertex(id, detail);
    }

    /**
     * @brief Get the current number of vertives.
     *
     */
    std::size_t numVertices()
    {
        return boost::num_vertices(detail);
    }

    /**
     * @brief Merge edges of the second vertex into the first vertex.
     *
     * @param v1
     * @param v2
     */
    void mergeVertices(std::size_t v1, std::size_t v2)
    {
        // obtain vertex descriptor
        vertex_descriptor v1d = boost::vertex(v1, detail);
        vertex_descriptor v2d = boost::vertex(v2, detail);

        // get iterator range for adjacent vertices of second vertex
        adjacency_iterator ai, ai_end, next;
        boost::tie(ai, ai_end) = boost::adjacent_vertices(v2d, detail);

        auto edge_index_map = get(boost::edge_index_t(), detail);

        // iterate over adjacent vertices
        for (next = ai; ai != ai_end; ai = next)
        {
            ++next;

            // obtain the corresponding edge from vertices
            std::pair<edge_descriptor, bool> e = boost::edge(v2d, *ai, detail);
            edge_descriptor edge = e.first;

            auto index = boost::get(edge_index_map, edge);

            vertex_descriptor target = boost::target(edge, detail);
            if (e.second && target != v1d)
            {
                vertex_descriptor source = boost::source(edge, detail);
                boost::remove_edge(edge, detail);

                e = boost::add_edge(v1d, target, detail);
                boost::put(edge_index_map, e.first, index);
            }
        }

        
        // clear and remove dest vertex
        boost::clear_vertex(v2d, detail);
        boost::remove_vertex(v2d, detail);
    }

    /**
     * @brief Get current vertex ids.
     *
     * @return std::set<std::size_t>
     */
    std::set<std::size_t> getVertexSet()
    {
        std::set<std::size_t> result = {};

        vertex_index_property_map_t vertex_ids = boost::get(boost::vertex_index_t(), detail);

        vertex_iterator vi, vi_end, next;
        boost::tie(vi, vi_end) = boost::vertices(detail);
        for (next = vi; vi != vi_end; vi = next)
        {
            ++next;
            result.insert(vertex_ids[*vi]);
        }

        return result;
    }

    /**
     * @brief Get the Vertex objects
     *
     * @return std::unordered_set<Vertex>
     */
    std::unordered_set<vertex_descriptor> getVertices()
    {
        std::unordered_set<vertex_descriptor> result = {};

        vertex_iterator vi, vi_end, next;
        boost::tie(vi, vi_end) = boost::vertices(detail);
        for (next = vi; vi != vi_end; vi = next)
        {
            ++next;
            result.insert(boost::vertex(*vi, detail));
        }
        return result;
    }

    /**
     * @brief Remove all vertices from the graph.
     * All edges corresponding to the vertex are removed beforehand.
     *
     */
    void removeVertices()
    {
        vertex_iterator vi, vi_end, next;
        boost::tie(vi, vi_end) = boost::vertices(detail);
        for (next = vi; vi != vi_end; vi = next)
        {
            ++next;
            boost::clear_vertex(*vi, detail); // ensure all edges to vertex are removed beforehand
            boost::remove_vertex(*vi, detail);
        }
    }

    /**
     * @brief Add a new edge to the graph with a (optionally) custom Id (default 0).
     *
     * @param src
     * @param dest
     * @param customId
     * @return auto
     */
    auto addEdge(std::size_t src, std::size_t dest, int customId = 0)
    {
        auto s = boost::vertex(src, detail);
        auto d = boost::vertex(dest, detail);
        auto e = boost::add_edge(s, d, customId, detail);
        assert(e.second == true);
        edgeMap[customId].emplace_back(e.first);
        return e.first;
    }

    /**
     * @brief Add multiple edges via list of pairs src, dest.
     *
     * @param edges
     */
    void addEdges(std::list<std::pair<std::size_t, std::size_t>> edges)
    {
        for (auto edge : edges)
        {
            auto e = boost::add_edge(edge.first, edge.second, 0, detail);
            assert(e.second == true);
            edgeMap[0].emplace_back(e.first);
        }
    }

    /**
     * @brief Add multiple edges via list of tuples src, dest, id.
     *
     * @param edges
     */
    void addEdges(std::list<std::tuple<std::size_t, std::size_t, int>> edges)
    {
        for (auto edge : edges)
        {
            std::size_t src, dest;
            int id;
            std::tie(src, dest, id) = edge;
            auto e = boost::add_edge(src, dest, id, detail);
            assert(e.second == true);
            edgeMap[0].emplace_back(e.first);
        }
    }

    /**
     * @brief Get the current number of edges.
     *
     * @return std::size_t
     */
    std::size_t numEdges()
    {
        return boost::num_edges(detail);
    }

    /**
     * @brief Get all edges belonging to a id.
     *
     * @param id
     * @return const std::vector<edge_descriptor>&
     */
    const std::vector<edge_descriptor> &getEdgesById(int id)
    {
        return edgeMap[id];
    }

    /**
     * @brief Get the Edge Map object
     *
     * @return const std::unordered_map<int, std::vector<edge_descriptor>>&
     */
    const std::unordered_map<int, std::vector<edge_descriptor>> &getEdgeMap()
    {
        return edgeMap;
    }

    /**
     * @brief Get current edge ids.
     *
     * @return std::set<std::size_t>
     */
    std::set<std::size_t> getEdgeIds()
    {
        std::set<std::size_t> result = {};

        edge_index_property_map_t edge_ids = boost::get(boost::edge_index_t(), detail);

        edge_iterator ei, ei_end, next;
        boost::tie(ei, ei_end) = boost::edges(detail);
        for (next = ei; ei != ei_end; ei = next)
        {
            ++next;
            result.insert(edge_ids[*ei]);
        }

        return result;
    }

    /**
     * @brief Remove edges by id.
     *
     * @param id
     */
    void removeEdgesById(std::size_t id)
    {
        for (edge_descriptor edge : edgeMap[id])
            boost::remove_edge(edge, detail);
        edgeMap.erase(id);
    }

private:
    std::unordered_map<int, std::vector<edge_descriptor>> edgeMap;

    // store connected components
    std::vector<std::vector<std::size_t>> mConnectedComponents = {};

    // typedef typename boost::property_map<graph_t, boost::edge_index_t>::type edge_index_pm;
    // typedef typename boost::graph_traits<graph_t>::vertex_descriptor vertex;
    // typedef typename boost::graph_traits<graph_t>::adjacency_iterator Adjacency_Iterator;
};

#endif // NCONPP_GRAPH_H
