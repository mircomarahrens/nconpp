#include <gtest/gtest.h>
#include <gmock/gmock-matchers.h>

#include "Graph.h"

using ::testing::ElementsAre;

class GraphTest : public testing::Test
{
    GraphTest() = default;

    ~GraphTest() override = default;
};

TEST(GraphTest, baseline)
{
    Graph<> g(6);

    g.addVertex();

    ASSERT_TRUE(g.numVertices() == 7);

    g.removeVertex(2);

    ASSERT_TRUE(g.numVertices() == 6);

    auto ids = g.getVertexSet();

    // identifiers in graph are always in ascending contiguous order starting with 0
    ASSERT_THAT(ids, ElementsAre(0, 1, 2, 3, 4, 5));

    // add one new edge between vertices with id 0 and 1
    g.addEdge(0, 1);

    // or add many of them via a list
    typedef std::pair<std::size_t, std::size_t> Pair;
    std::list<Pair> edgeList = {
        Pair(0, 2),
        Pair(0, 3),
        Pair(2, 0),
        Pair(3, 4),
        Pair(4, 1),
    };

    ASSERT_TRUE(edgeList.size() == 5);

    // add edges to Graph object
    g.addEdges(edgeList);

    ASSERT_TRUE(g.numEdges() == 6);

    // Graph allows parallel edges per default, known as multigraph
    g.addEdge(2, 0);

    ASSERT_TRUE(g.numEdges() == 7);

    std::set<std::size_t> edgeIds = g.getEdgeIds();

    // Egdes are added via a custom identifier with a default value of 0, hence
    ASSERT_TRUE(edgeIds.size() == 1);

    g.addEdge(2, 3, 1);

    edgeIds = g.getEdgeIds();

    ASSERT_TRUE(g.numEdges() == 8);
    ASSERT_TRUE(edgeIds.size() == 2);

    ASSERT_THAT(edgeIds, ElementsAre(0,1));

    std::vector<Graph<>::edge_descriptor> edges = g.getEdgesById(0);

    ASSERT_TRUE(edges.size() == 7);

    edges = g.getEdgesById(1);

    ASSERT_TRUE(edges.size() == 1);

    g.removeEdgesById(0);

    edges = g.getEdgesById(0);

    ASSERT_TRUE(edges.size() == 0);

    edges = g.getEdgesById(1);

    ASSERT_TRUE(edges.size() == 1);

    ASSERT_TRUE(edges[0].m_source == 2);
    ASSERT_TRUE(edges[0].m_target == 3);
}
