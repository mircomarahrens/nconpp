{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 28,
        "patch": 0
      },
    "configurePresets": [
        {
            "name": "default-linux",
            "displayName": "Default Config",
            "description": "Default build using Ninja generator.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "vendor": {
                "microsoft.com/VisualStudioSettings/CMake/1.0": {
                    "hostOS": [
                        "Linux"
                    ]
                },
                "microsoft.com/VisualStudioRemoteSettings/CMake/1.0": {
                    "sourceDir": "$env{HOME}/.vs/$ms{projectDirName}"
                }
            }
        },
        {
            "name": "user-configure-debug",
            "description": "User specified configure preset using vcpkg.",
            "displayName": "configure debug (user)",
            "inherits": "default-linux",
            "environment": {
                "VCPKG_ROOT": "${sourceDir}/utils/vcpkg",
                "PYTHON_VENV": "${sourceDir}/.venv"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "Python_EXECUTABLE": "${sourceDir}/.venv/bin/python"
            }
        }
    ],
    "buildPresets": [
      {
        "name": "user-default",
        "configurePreset": "default-linux"
      }
    ],
    "testPresets": [
        {
            "name": "user-googletests-debug",
            "description": "User specified test preset running googletest.",
            "displayName": "googletest debug (user)",
            "configurePreset": "user-configure-debug"
        }
    ]
}